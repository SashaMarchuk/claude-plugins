<!--
  This is a shipped template. Copy it to your run directory before editing -- direct edits
  to this file will be wiped on /plugin update.

  claude-migrate copy page (the reliable floor). build-copy-page assembles out/index.html
  from this shell by substituting the placeholder tokens below. It is self-contained,
  domain-neutral, and works from any static host. Open it via `python3 -m http.server`
  (see out/README.md); the file:// scheme blocks the clipboard API in most browsers and
  forces the textarea fallback.

  Generator substitutions (build-copy-page). Each token below appears EXACTLY ONCE in this
  file (in its live slot, never here in this comment), so a global string replace is safe and
  unambiguous. The tokens are written with a leading underscore here so this documentation does
  not itself get substituted:
    _RUN_                    run id; becomes part of the localStorage key (per-run marks).
    _GROUP_LABEL_GROUPED_    config display label for bucket role GROUPED.
    _GROUP_LABEL_STANDALONE_ config display label for bucket role STANDALONE.
    _GROUP_LABEL_REFERENCE_  config display label for bucket role REFERENCE.
    _DATA_JSON_              the JSON array of items. Each item:
                                 { id, group, kind, num, name, body? }
                             group is one of the closed bucket roles plus "project"
                             (the per-project instructions card). When the run exceeds
                             the inline threshold, `body` is OMITTED and the page lazy-
                             loads it from payloads/<id>.json on demand. Every "</script"
                             inside this JSON MUST be escaped via /<\/(script)/gi -> "<\/$1"
                             (case-insensitive) so the data block cannot terminate early.

  The live tokens (substitute these, each appears once): the run id token, the three
  GROUP_LABEL tokens, and the DATA_JSON token, all wrapped in double curly braces.
-->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Claude account migration - copy your chats</title>
<style>
  :root{
    --bg:#f4f5f7; --card:#ffffff; --ink:#1f2328; --muted:#6b7280; --line:#e3e6ea;
    --accent:#c96442; --accent2:#0b7; --done:#1a9d5a; --doneBg:#eafaf0; --err:#c0392b; --errBg:#fdecea;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font:15px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
  header{position:sticky;top:0;z-index:10;background:rgba(255,255,255,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);padding:12px 18px}
  .htop{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
  h1{font-size:17px;margin:0;font-weight:650}
  .counter{font-weight:700;color:var(--accent)}
  .bar{flex:1;min-width:140px;height:8px;background:#e8ebef;border-radius:6px;overflow:hidden}
  .bar > i{display:block;height:100%;width:0;background:var(--done);transition:width .25s}
  input[type=search]{flex:1;min-width:180px;padding:8px 12px;border:1px solid var(--line);border-radius:9px;font-size:14px;background:#fff}
  button{font:inherit;cursor:pointer;border:1px solid var(--line);background:#fff;border-radius:9px;padding:7px 12px;transition:.12s}
  button:hover{border-color:#c4c9d0;background:#fafbfc}
  button:active{transform:translateY(1px)}
  button:focus-visible,input[type=search]:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
  .btn-primary{background:var(--accent);color:#fff;border-color:var(--accent);font-weight:600}
  .btn-primary:hover{background:#b4583a;border-color:#b4583a}
  .btn-ghost{padding:7px 10px;color:var(--muted)}
  .wrap{max-width:1000px;margin:0 auto;padding:18px}
  .sec{margin:22px 0 8px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);font-weight:700}
  .card{background:var(--card);border:1px solid var(--line);border-left:4px solid var(--line);border-radius:12px;padding:14px 16px;margin:10px 0;box-shadow:0 1px 2px rgba(16,24,40,.04)}
  .card.copied{border-left-color:var(--done);background:linear-gradient(0deg,var(--doneBg),#fff 60%)}
  .card.copy-error{border-left-color:var(--err);background:linear-gradient(0deg,var(--errBg),#fff 60%)}
  .crow{display:flex;align-items:flex-start;gap:12px}
  .num{flex:0 0 auto;width:30px;height:30px;border-radius:8px;background:#f0f2f5;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--muted);font-size:13px}
  .card.copied .num{background:var(--done);color:#fff}
  .meta{flex:1;min-width:0}
  .name{font-weight:650;font-size:15px;word-break:break-word}
  .tags{margin-top:3px;font-size:12px;color:var(--muted)}
  .badge{display:none;align-items:center;gap:5px;color:var(--done);font-weight:700;font-size:12.5px;margin-top:5px}
  .card.copied .badge{display:inline-flex}
  .errnote{display:none;align-items:center;gap:5px;color:var(--err);font-weight:700;font-size:12.5px;margin-top:5px}
  .card.copy-error .errnote{display:inline-flex}
  .acts{flex:0 0 auto;display:flex;gap:7px;align-items:center;flex-wrap:wrap;justify-content:flex-end}
  pre{display:none;white-space:pre-wrap;word-break:break-word;background:#fbfcfd;border:1px solid var(--line);border-radius:9px;padding:12px;margin:12px 0 0;font:13px/1.5 ui-monospace,SFMono-Regular,Menlo,monospace;max-height:340px;overflow:auto}
  pre.open{display:block}
  .toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(20px);background:#1f2328;color:#fff;padding:10px 18px;border-radius:10px;opacity:0;pointer-events:none;transition:.2s;font-weight:600;z-index:50;max-width:80vw;text-align:center}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .toast.err{background:var(--err)}
  .hide{display:none !important}
  .hint{color:var(--muted);font-size:13px;margin:2px 0 0}
  @media(max-width:620px){ .crow{flex-wrap:wrap} .acts{width:100%;justify-content:flex-start} }
</style>
</head>
<body>
<header>
  <div class="htop">
    <h1>Claude account migration</h1>
    <span class="counter"><span id="cnt">0</span> / <span id="tot">0</span> copied</span>
    <div class="bar" role="progressbar" aria-label="Migration progress" aria-valuemin="0" aria-valuenow="0" id="bar"><i id="barfill"></i></div>
    <input id="search" type="search" placeholder="Search by chat name..." aria-label="Search chats by name">
    <button class="btn-ghost" id="nextBtn" title="Jump to the first chat not yet copied">Next uncopied</button>
    <button class="btn-ghost" id="resetBtn" title="Clear all copied marks">Reset</button>
  </div>
  <p class="hint"><b>1)</b> "Copy brief" then paste it as the FIRST message in a new chat. <b>2)</b> Wait for the assistant's first reply (that is when Claude auto-titles the chat). <b>3)</b> Only then rename: "Copy name" then paste it into the title field. Renaming BEFORE the first reply lets the auto-title overwrite it. The copied mark is stored in this browser only.</p>
</header>
<div class="wrap" id="list"></div>
<div class="toast" id="toast" role="status" aria-live="polite">Copied</div>

<script id="data" type="application/json">{{DATA_JSON}}</script>
<script>
"use strict";
// Parse the embedded data as DATA (NEVER via innerHTML). The data block escapes any
// "</script" so it cannot terminate early; we read it back with textContent + JSON.parse.
var DATA = JSON.parse(document.getElementById("data").textContent);
// Per-run localStorage key: marks are scoped to this run so re-running does not collide.
var RUN = "{{RUN}}";
var KEY = "claudeMig.copied." + RUN + ".v1";
// Display labels for the closed bucket roles, supplied by config (never hardcoded domain terms).
var GROUPS = [
  ["project",    "Project instructions"],
  ["GROUPED",    "{{GROUP_LABEL_GROUPED}}"],
  ["STANDALONE", "{{GROUP_LABEL_STANDALONE}}"],
  ["REFERENCE",  "{{GROUP_LABEL_REFERENCE}}"]
];
// Test hook: set to the exact text of the last copy attempt (success OR fallback).
window.__lastCopied = null;
// In-memory cache for lazy-loaded payload bodies (over the inline threshold).
var bodyCache = {};

function getMarks(){ try{ return JSON.parse(localStorage.getItem(KEY)) || {}; }catch(e){ return {}; } }
function setMarks(m){ try{ localStorage.setItem(KEY, JSON.stringify(m)); }catch(e){} }

// Resolve the brief body for an item. If `body` is inlined, return it; otherwise lazy-load
// payloads/<id>.json (shape: { body: "..." }) and cache it. Always returns a Promise<string>.
function getBody(d){
  if (typeof d.body === "string") return Promise.resolve(d.body);
  if (Object.prototype.hasOwnProperty.call(bodyCache, d.id)) return Promise.resolve(bodyCache[d.id]);
  return fetch("payloads/" + encodeURIComponent(d.id) + ".json")
    .then(function(r){ if(!r.ok) throw new Error("payload " + r.status); return r.json(); })
    .then(function(p){ var body = (p && typeof p.body === "string") ? p.body : ""; bodyCache[d.id] = body; return body; });
}

// Copy `text`. Resolves true on a CONFIRMED copy (writeText resolved OR execCommand returned
// true), false otherwise. Sets window.__lastCopied on every attempt.
function copyText(text){
  window.__lastCopied = text;
  if (navigator.clipboard && navigator.clipboard.writeText){
    try{
      return Promise.resolve(navigator.clipboard.writeText(text))
        .then(function(){ return true; })
        .catch(function(){ return fallbackCopy(text); });
    }catch(e){
      return Promise.resolve(fallbackCopy(text));
    }
  }
  return Promise.resolve(fallbackCopy(text));
}
// Synchronous fallback: a focused, selected, offscreen textarea + execCommand("copy").
function fallbackCopy(text){
  try{
    var ta=document.createElement("textarea");
    ta.value=text; ta.setAttribute("readonly","");
    ta.style.position="fixed"; ta.style.top="-1000px"; ta.style.opacity="0";
    document.body.appendChild(ta); ta.focus(); ta.select();
    ta.setSelectionRange(0, text.length);
    var ok=document.execCommand("copy");
    document.body.removeChild(ta);
    return ok === true;
  }catch(e){ return false; }
}
// Last-resort manual recovery: drop a focused, fully-selected textarea into the card so the
// user can press Cmd/Ctrl-C themselves. Used only when an automatic copy failed.
function selectForManualCopy(card, text){
  try{
    var ta=document.createElement("textarea");
    ta.className="manual-copy";
    ta.value=text; ta.setAttribute("readonly","");
    ta.style.width="100%"; ta.style.marginTop="10px"; ta.style.minHeight="120px";
    ta.style.font="13px/1.5 ui-monospace,SFMono-Regular,Menlo,monospace";
    var prev=card.querySelector("textarea.manual-copy");
    if(prev) prev.parentNode.removeChild(prev);
    card.appendChild(ta);
    ta.focus(); ta.select(); ta.setSelectionRange(0, text.length);
  }catch(e){}
}

var toastT=null;
function toast(msg, isErr){
  var t=document.getElementById("toast");
  t.textContent=msg; t.classList.toggle("err", !!isErr); t.classList.add("show");
  clearTimeout(toastT); toastT=setTimeout(function(){ t.classList.remove("show"); }, isErr?3000:1200);
}

function totalCount(){ return DATA.length; }
function updateCounter(){
  var marks=getMarks();
  var c=DATA.reduce(function(n,d){ return n + (marks[d.id]?1:0); },0);
  var tot=totalCount();
  document.getElementById("cnt").textContent=c;
  document.getElementById("tot").textContent=tot;
  document.getElementById("barfill").style.width=(tot? (100*c/tot):0)+"%";
  var bar=document.getElementById("bar");
  if(bar){ bar.setAttribute("aria-valuemax", tot); bar.setAttribute("aria-valuenow", c); }
}
function applyMark(id){
  var card=document.getElementById("card-"+id);
  if(card){ card.classList.remove("copy-error"); card.classList.add("copied"); }
}

// Copy a brief. Marks + persists ONLY on a confirmed successful copy (Edge H-5). On failure
// the card enters an error state and the brief text is selected for manual Cmd/Ctrl-C.
function onCopyBrief(d){
  var card=document.getElementById("card-"+d.id);
  getBody(d).then(function(body){
    return copyText(body).then(function(ok){
      if(ok !== true){
        if(card){ card.classList.remove("copied"); card.classList.add("copy-error"); selectForManualCopy(card, body); }
        toast("Copy failed - text selected, press Cmd/Ctrl-C", true);
        return;
      }
      var marks=getMarks(); if(!marks[d.id]) marks[d.id]=Date.now(); setMarks(marks);
      applyMark(d.id); updateCounter(); toast("Copied: "+d.name);
    });
  }).catch(function(){
    if(card){ card.classList.add("copy-error"); }
    toast("Could not load this brief", true);
  });
}
// Copy a chat's target name. Toasts; does NOT mark the card copied.
function onCopyName(d){
  copyText(d.name).then(function(ok){ toast(ok===true?"Name copied":"Copy failed - paste manually", ok!==true); });
}

function render(){
  var list=document.getElementById("list");
  var marks=getMarks();
  GROUPS.forEach(function(g){
    var items=DATA.filter(function(d){ return d.group===g[0]; });
    if(!items.length) return;
    var h=document.createElement("div"); h.className="sec"; h.textContent=g[1]+" ("+items.length+")";
    list.appendChild(h);
    items.forEach(function(d){
      var card=document.createElement("div");
      card.className="card"+(marks[d.id]?" copied":"");
      card.id="card-"+d.id;
      card.setAttribute("data-name",(d.name||"").toLowerCase());

      var row=document.createElement("div"); row.className="crow";
      var num=document.createElement("div"); num.className="num"; num.textContent=d.num; row.appendChild(num);

      var meta=document.createElement("div"); meta.className="meta";
      var nm=document.createElement("div"); nm.className="name"; nm.textContent=d.name; meta.appendChild(nm);
      var bd=document.createElement("div"); bd.className="badge"; bd.textContent="✓ already copied"; meta.appendChild(bd);
      var er=document.createElement("div"); er.className="errnote"; er.textContent="⚠ copy failed - text selected below, press Cmd/Ctrl-C"; meta.appendChild(er);
      row.appendChild(meta);

      var acts=document.createElement("div"); acts.className="acts";
      var b1=document.createElement("button"); b1.className="btn-primary"; b1.textContent="Copy brief";
      b1.addEventListener("click",function(){ onCopyBrief(d); });
      acts.appendChild(b1);
      if(d.kind!=="instructions"){
        var b2=document.createElement("button"); b2.textContent="Copy name";
        b2.addEventListener("click",function(){ onCopyName(d); });
        acts.appendChild(b2);
      }
      var b3=document.createElement("button"); b3.className="btn-ghost"; b3.textContent="Show";
      b3.setAttribute("aria-controls","pre-"+d.id); b3.setAttribute("aria-expanded","false");
      acts.appendChild(b3);
      row.appendChild(acts);
      card.appendChild(row);

      var pre=document.createElement("pre"); pre.id="pre-"+d.id; card.appendChild(pre);
      var preLoaded=false;
      b3.addEventListener("click",function(){
        var open=pre.classList.toggle("open");
        b3.textContent=open?"Hide":"Show"; b3.setAttribute("aria-expanded", open?"true":"false");
        if(open && !preLoaded){
          preLoaded=true;
          getBody(d).then(function(body){ pre.textContent=body; }).catch(function(){ pre.textContent="(could not load brief)"; });
        }
      });

      list.appendChild(card);
    });
  });
  updateCounter();
}

function applyFilter(qraw){
  var q=(qraw||"").trim().toLowerCase();
  var cards=document.querySelectorAll(".card");
  for(var i=0;i<cards.length;i++){
    var c=cards[i];
    c.classList.toggle("hide", !!q && (c.getAttribute("data-name")||"").indexOf(q)<0);
  }
  var secs=document.querySelectorAll(".sec");
  for(var j=0;j<secs.length;j++){
    var sec=secs[j], anyVisible=false, n=sec.nextElementSibling;
    while(n && !n.classList.contains("sec")){
      if(n.classList.contains("card") && !n.classList.contains("hide")){ anyVisible=true; break; }
      n=n.nextElementSibling;
    }
    sec.classList.toggle("hide", !!q && !anyVisible);
  }
}

document.getElementById("search").addEventListener("input",function(e){ applyFilter(e.target.value); });
document.getElementById("nextBtn").addEventListener("click",function(){
  var el=document.querySelector(".card:not(.copied):not(.hide)");
  if(el){ el.scrollIntoView({behavior:"smooth",block:"center"}); el.style.outline="2px solid var(--accent)"; setTimeout(function(){el.style.outline="";},1200); }
  else toast("Everything is copied");
});
document.getElementById("resetBtn").addEventListener("click",function(){
  if(!confirm("Clear all copied marks?")) return;
  setMarks({});
  var done=document.querySelectorAll(".card.copied");
  for(var i=0;i<done.length;i++){ done[i].classList.remove("copied"); }
  updateCounter(); toast("Marks cleared");
});

render();
</script>
</body>
</html>
